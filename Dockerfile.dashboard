FROM node:20-slim

WORKDIR /app

COPY dashboard/package*.json ./
RUN npm ci

COPY dashboard/ ./

RUN npm run build

# Run as non-root user
RUN useradd -m -r -s /bin/false appuser && chown -R appuser:appuser /app
USER appuser

EXPOSE 5174

CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "5174"]
